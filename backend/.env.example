# Backend Environment Configuration
ENVIRONMENT=development
PORT=8000

# Database Connection URL (SQLite default for local, PostgreSQL for Render/Railway)
# Local SQLite example: sqlite:///./school.db
# PostgreSQL example: postgresql://user:password@localhost:5473/school_db
DATABASE_URL=sqlite:///./school.db

# JWT Configuration (Create a strong random secret using `openssl rand -hex 32`)
JWT_SECRET=supersecretchangeinproduction
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API Configuration (Get your key from Google AI Studio)
GEMINI_API_KEY=your_google_gemini_api_key_here
